generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id           String     @id @default(uuid())
  name         String
  description  String?
  sku          String     @unique
  minStock     Int
  currentStock Int        @default(0)
  unit         String     @default("units")
  category     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  movements    Movement[]
  alerts       Alert[]
}

model Movement {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  type      String
  quantity  Int
  reason    String?
  createdAt DateTime @default(now())
}

model Alert {
  id         String    @id @default(uuid())
  productId  String
  product    Product   @relation(fields: [productId], references: [id])
  type       String
  message    String
  resolved   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}
